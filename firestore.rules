rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }
    
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidSavedWord(data) {
      return data.keys().hasAll(['wordData']) &&
             data.wordData is string && data.wordData.size() <= 60000;
    }

    function isValidLearningSession(data) {
      return data.keys().hasAll(['sessionData']) &&
             data.sessionData is string && data.sessionData.size() <= 200000;
    }

    match /users/{userId}/savedWords/{wordId} {
      allow read, list: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(wordId);
      
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(wordId) &&
                       isValidSavedWord(incoming());
                       
      allow update: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(wordId) &&
                       isValidSavedWord(incoming());
                       
      allow delete: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(wordId);
    }

    match /users/{userId}/sessions/{sessionId} {
      allow read, list: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(sessionId);
      
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(sessionId) &&
                       isValidLearningSession(incoming());
                       
      allow update: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(sessionId) &&
                       isValidLearningSession(incoming());
                       
      allow delete: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(sessionId);
    }
  }
}
